{
  "name": "kamod-hooks",
  "description": "Preact hooks ported from ahooks — zero runtime dependencies.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Klaus Zahiragic <watzak>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kamod-ch/kamod-hooks.git"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm --filter @kamod-ch/hooks test",
    "test:ci": "pnpm test",
    "typecheck": "pnpm -r typecheck",
    "demo": "pnpm docs:dev",
    "docs:dev": "pnpm --filter @kamod-hooks/docs dev",
    "docs:check": "pnpm --filter @kamod-hooks/docs check",
    "docs:build": "pnpm --filter @kamod-ch/hooks build && pnpm --filter @kamod-hooks/docs build",
    "docs:preview": "pnpm --filter @kamod-hooks/docs preview",
    "sync:readmes": "node scripts/sync-readmes.mjs",
    "qa:publint": "pnpm --filter @kamod-ch/hooks publint",
    "qa:attw": "pnpm --filter @kamod-ch/hooks attw",
    "qa:package": "pnpm --filter @kamod-ch/hooks build && pnpm qa:publint && pnpm qa:attw",
    "verify": "pnpm typecheck && pnpm test:ci && pnpm build && pnpm qa:package && pnpm docs:check",
    "release": "node ./scripts/release.mjs patch",
    "release:minor": "node ./scripts/release.mjs minor",
    "release:major": "node ./scripts/release.mjs major",
    "release:dry": "node ./scripts/release.mjs patch --dry"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  },
  "packageManager": "pnpm@10.12.4"
}
