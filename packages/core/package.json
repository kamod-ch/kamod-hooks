{
  "name": "@kamod-hooks/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Preact hooks — zero runtime npm dependencies (peer: preact only).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kamod-ch/kamod-hooks.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only"
  },
  "peerDependencies": {
    "preact": "^10.29.2"
  },
  "dependencies": {},
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@types/node": "^25.9.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "jsdom": "^29.1.1",
    "preact": "^10.29.2",
    "preact-render-to-string": "^6.7.0",
    "publint": "^0.3.21",
    "tsup": "^8.5.1",
    "vitest": "^4.1.8"
  }
}
